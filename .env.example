# Vercel Deployment Environment Variables
# Copy these to your Vercel project settings

# Database (Vercel Postgres or external)
DATABASE_URL="postgresql://user:password@host:5432/safeledger"

# Redis (Vercel KV or external)
REDIS_URL="redis://user:password@host:6379"

# JWT Configuration
JWT_SECRET="your-super-secure-jwt-secret-key-for-production"
JWT_EXPIRE="7d"

# Encryption (AES-256 - 32 characters exactly)
ENCRYPTION_KEY="my-32-character-encryption-key!!"

# Hedera Configuration
HEDERA_NETWORK="testnet" # Change to "mainnet" for production
HEDERA_ACCOUNT_ID="0.0.xxxxxx"
HEDERA_PRIVATE_KEY="302e020100300506032b657004220420..."
HEDERA_TOPIC_ID="" # Optional: Set after first deployment

# M-Pesa (Production)
MPESA_CONSUMER_KEY=""
MPESA_CONSUMER_SECRET=""
MPESA_PASSKEY=""
MPESA_SHORTCODE=""

# Application
NODE_ENV="production"
PORT="5000"
